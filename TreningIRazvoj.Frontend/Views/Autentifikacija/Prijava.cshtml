@model TreningIRazvoj.Frontend.Models.Autentifikacija.PrijavaKorisnikaModel

@{
    ViewData["Title"] = "Prijava";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow">
            <div class="card-body p-4">

                <h2 class="text-center mb-2">
                    Prijavljivanje
                </h2>

                <p class="text-center text-muted mb-4">
                    Sistem za upravljanje treningom i razvojem zaposlenih
                </p>

                <form asp-controller="Autentifikacija"
                      asp-action="Prijava"
                      method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"
                         role="alert">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Imejl"
                               class="form-label">
                        </label>

                        <input asp-for="Imejl"
                               class="form-control"
                               placeholder="admin@firma.rs"
                               autocomplete="email" />

                        <span asp-validation-for="Imejl"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Lozinka"
                               class="form-label">
                        </label>

                        <input asp-for="Lozinka"
                               class="form-control"
                               placeholder="Unesite lozinku"
                               autocomplete="current-password" />

                        <span asp-validation-for="Lozinka"
                              class="text-danger">
                        </span>
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        Prijavi se
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}