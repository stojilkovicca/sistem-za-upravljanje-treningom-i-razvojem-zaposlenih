@model TreningIRazvoj.Frontend.Models.Autentifikacija.RegistracijaKorisnikaModel

@{
    ViewData["Title"] = "Registracija korisnika";
}

<h1>Registracija korisnika</h1>

<p class="text-muted">
    Administrator kreira nalog i dodeljuje odgovarajuću ulogu.
</p>

<hr />

<form asp-action="Registracija" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger">
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Ime" class="form-label"></label>
            <input asp-for="Ime" class="form-control" />
            <span asp-validation-for="Ime" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Prezime" class="form-label"></label>
            <input asp-for="Prezime" class="form-control" />
            <span asp-validation-for="Prezime" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Imejl" class="form-label"></label>
            <input asp-for="Imejl" class="form-control" />
            <span asp-validation-for="Imejl" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Lozinka" class="form-label"></label>
            <input asp-for="Lozinka" class="form-control" />
            <span asp-validation-for="Lozinka" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Uloga" class="form-label"></label>

            <select asp-for="Uloga" class="form-select">
                <option value="Administrator">Administrator</option>
                <option value="HR">HR</option>
                <option value="Zaposleni">Zaposleni</option>
            </select>

            <span asp-validation-for="Uloga" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">
        Registruj korisnika
    </button>

    <a asp-controller="Pocetna"
       asp-action="Index"
       class="btn btn-outline-secondary">
        Odustani
    </a>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}