@model IEnumerable<TreningIRazvoj.Frontend.Models.Kategorije.KategorijaProgramaModel>

@{
    ViewData["Title"] = "Kategorije";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Kategorije programa</h1>
        <p class="text-muted mb-0">
            Upravljanje kategorijama razvojnih programa.
        </p>
    </div>

    <div>
        <a asp-action="Kreiraj" class="btn btn-primary">
            Dodaj kategoriju
        </a>

        <a asp-controller="Pocetna"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Nazad
        </a>
    </div>
</div>

@if (ViewBag.Greska is not null)
{
    <div class="alert alert-danger">@ViewBag.Greska</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nema evidentiranih kategorija.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Naziv</th>
                    <th>Opis</th>
                    <th>Akcije</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var kategorija in Model)
                {
                    <tr>
                        <td>@kategorija.Id</td>
                        <td>@kategorija.Naziv</td>
                        <td>@kategorija.Opis</td>

                        <td class="text-nowrap">
                            <a asp-action="Izmeni"
                               asp-route-id="@kategorija.Id"
                               class="btn btn-sm btn-warning">
                                Izmeni
                            </a>

                            <form asp-action="Obrisi"
                                  asp-route-id="@kategorija.Id"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Obrisati kategoriju?');">

                                @Html.AntiForgeryToken()

                                <button class="btn btn-sm btn-danger">
                                    Obriši
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}