@model TreningIRazvoj.Frontend.Models.RazvojniProgrami.RazvojniProgramModel

@{
    ViewData["Title"] = "Dodavanje programa";
}

<h1>Dodavanje razvojnog programa</h1>
<hr />

<form asp-action="Kreiraj" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger">
    </div>

    <partial name="_Forma" model="Model" />

    <button class="btn btn-primary">
        Sačuvaj
    </button>

    <a asp-action="Index"
       class="btn btn-outline-secondary">
        Odustani
    </a>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}