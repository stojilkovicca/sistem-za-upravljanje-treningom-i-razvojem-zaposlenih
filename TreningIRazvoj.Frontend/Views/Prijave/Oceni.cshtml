@model TreningIRazvoj.Frontend.Models.Prijave.OceniProgramModel

@{
    ViewData["Title"] = "Ocenjivanje programa";
}

<h1>Ocenjivanje programa</h1>

<div class="mb-4">
    <strong>Zaposleni:</strong>
    @Model.ImeIPrezimeZaposlenog

    <br />

    <strong>Program:</strong>
    @Model.NazivRazvojnogPrograma
</div>

<form asp-action="Oceni" method="post">
    @Html.AntiForgeryToken()

    <input asp-for="ZaposleniId" type="hidden" />
    <input asp-for="RazvojniProgramId" type="hidden" />
    <input asp-for="ImeIPrezimeZaposlenog" type="hidden" />
    <input asp-for="NazivRazvojnogPrograma" type="hidden" />

    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger">
    </div>

    <div class="mb-3">
        <label asp-for="OcenaPrograma"
               class="form-label">
        </label>

        <select asp-for="OcenaPrograma"
                class="form-select">
            <option value="1">1 — veoma loše</option>
            <option value="2">2 — loše</option>
            <option value="3">3 — dobro</option>
            <option value="4">4 — veoma dobro</option>
            <option value="5">5 — odlično</option>
        </select>

        <span asp-validation-for="OcenaPrograma"
              class="text-danger">
        </span>
    </div>

    <button class="btn btn-primary">
        Sačuvaj ocenu
    </button>

    <a asp-action="Index"
       class="btn btn-outline-secondary">
        Odustani
    </a>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}